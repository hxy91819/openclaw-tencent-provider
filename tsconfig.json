{
  "compilerOptions": {
    "declaration": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  },
  "include": ["./*.ts", "./openclaw.plugin.json"],
  "exclude": ["./dist/**", "./node_modules/**"]
}
