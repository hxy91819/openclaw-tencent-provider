# Local release settings for scripts/publish.sh.
# Copy values into .env; do not commit real tokens.

# Required for real ClawHub publish. Dry-run can use an existing clawhub login.
CLAWHUB_TOKEN=
CLAWHUB_OWNER=hxy91819
CLAWHUB_NAME=openclaw-tencent-test-provider
CLAWHUB_SOURCE_REPO=hxy91819/openclaw-tencent-provider
CLAWHUB_SOURCE_REF=main
CLAWHUB_CHANGELOG=Publish Tencent rehearsal package with runtime id tencent-test so testing does not claim the official Tencent plugin id.

# Optional ClawHub metadata.
CLAWHUB_REGISTRY=
CLAWHUB_TAGS=latest
CLAWHUB_CATEGORIES=
CLAWHUB_TOPICS=

# Required for real npm publish.
NPM_TOKEN=
NPM_REGISTRY=https://registry.npmjs.org/
NPM_TAG=latest
NPM_ACCESS=public
NPM_OTP=
